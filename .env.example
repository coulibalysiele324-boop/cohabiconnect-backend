# ============================================================
# CohabiConnect — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer .env sur GitHub
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Disponible dans : Supabase Dashboard > Settings > API
SUPABASE_URL=https://XXXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Sécurité Admin ────────────────────────────────────────
# Clé secrète pour protéger les routes /api/admin/*
# Générer avec : openssl rand -hex 32
ADMIN_SECRET_KEY=votre_cle_secrete_tres_longue_ici

# ── Resend (envoi email) ──────────────────────────────────
# Créer un compte sur https://resend.com (gratuit jusqu'à 3000 emails/mois)
# Ajouter et vérifier votre domaine dans Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=CohabiConnect <admin@cohabiconnect.ci>

# ── Application ───────────────────────────────────────────
# URL publique du site (après déploiement Vercel)
APP_URL=https://cohabiconnect.vercel.app
